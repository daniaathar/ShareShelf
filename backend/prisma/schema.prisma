generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemStatus { 
  AVAILABLE 
  UNAVAILABLE 
  ARCHIVED 
  }
enum BookingStatus { 
  PENDING_PAYMENT 
  CONFIRMED 
  PICKED_UP 
  RETURNED 
  COMPLETED 
  CANCELLED 
  }
enum PaymentStatus { 
  PENDING 
  HELD 
  RELEASED 
  FAILED 
  }
enum EvidencePhase { 
  PICKUP 
  RETURN 
  }
enum ComparisonVerdict { 
  PASS 
  REVIEW_REQUIRED 
  UNAVAILABLE 
  }

model User {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @db.VarChar(80)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash")
  city         String    @db.VarChar(80)
  area         String?   @db.VarChar(80)
  items        Item[]
  bookings     Booking[] @relation("renter_bookings")
  evidence     ConditionEvidence[] @relation("uploaded_evidence")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  @@map("users")
}

model Item {
  id               String     @id @default(uuid()) @db.Uuid
  ownerId          String     @map("owner_id") @db.Uuid
  owner            User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title            String     @db.VarChar(120)
  description      String
  pricePerDayMinor Int        @map("price_per_day_minor")
  depositMinor     Int        @default(0) @map("deposit_minor")
  city             String     @db.VarChar(80)
  area             String     @db.VarChar(80)
  status           ItemStatus @default(AVAILABLE)
  images           ItemImage[]
  bookings         Booking[]
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  @@index([city, area, status])
  @@map("items")
}

model ItemImage {
  id              String   @id @default(uuid()) @db.Uuid
  itemId          String   @map("item_id") @db.Uuid
  item            Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  url             String
  storagePublicId String   @map("storage_public_id")
  position        Int
  createdAt       DateTime @default(now()) @map("created_at")
  @@unique([itemId, position])
  @@map("item_images")
}

model Booking {
  id                 String        @id @default(uuid()) @db.Uuid
  itemId             String        @map("item_id") @db.Uuid
  item               Item          @relation(fields: [itemId], references: [id])
  renterId           String        @map("renter_id") @db.Uuid
  renter             User          @relation("renter_bookings", fields: [renterId], references: [id])
  startDate          DateTime      @db.Date @map("start_date")
  endDate            DateTime      @db.Date @map("end_date")
  totalRentalMinor   Int           @map("total_rental_minor")
  depositMinor       Int           @map("deposit_minor")
  status             BookingStatus @default(PENDING_PAYMENT)
  payment            Payment?
  evidence           ConditionEvidence[]
  comparison         ConditionComparison?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  @@index([itemId, startDate, endDate])
  @@index([renterId, status])
  @@map("bookings")
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  bookingId         String        @unique @map("booking_id") @db.Uuid
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amountMinor       Int           @map("amount_minor")
  currency          String        @default("PKR") @db.VarChar(3)
  status            PaymentStatus @default(PENDING)
  provider          String        @default("MOCK")
  providerReference String?       @unique @map("provider_reference")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  @@map("payments")
}

model ConditionEvidence {
  id              String        @id @default(uuid()) @db.Uuid
  bookingId       String        @map("booking_id") @db.Uuid
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  phase           EvidencePhase
  url             String
  storagePublicId String        @map("storage_public_id")
  uploadedById    String        @map("uploaded_by_id") @db.Uuid
  uploadedBy      User          @relation("uploaded_evidence", fields: [uploadedById], references: [id])
  createdAt       DateTime      @default(now()) @map("created_at")
  pickupComparison ConditionComparison? @relation("pickup_evidence")
  returnComparison ConditionComparison? @relation("return_evidence")
  @@unique([bookingId, phase])
  @@map("condition_evidence")
}

model ConditionComparison {
  id                String            @id @default(uuid()) @db.Uuid
  bookingId         String            @unique @map("booking_id") @db.Uuid
  booking           Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  pickupEvidenceId  String            @unique @map("pickup_evidence_id") @db.Uuid
  pickupEvidence    ConditionEvidence @relation("pickup_evidence", fields: [pickupEvidenceId], references: [id])
  returnEvidenceId  String            @unique @map("return_evidence_id") @db.Uuid
  returnEvidence    ConditionEvidence @relation("return_evidence", fields: [returnEvidenceId], references: [id])
  similarityScore   Decimal?          @db.Decimal(5, 4) @map("similarity_score")
  verdict           ComparisonVerdict
  provider          String
  providerResultJson Json?            @map("provider_result_json")
  createdAt         DateTime          @default(now()) @map("created_at")
  @@map("condition_comparisons")
}
